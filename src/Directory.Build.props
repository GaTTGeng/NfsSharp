<Project>
  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <IsPackable>true</IsPackable>
    <Version>1.0.0</Version>
    <Authors>NfsSharp</Authors>
    <Company>Chemical.AI</Company>
    <Description>Managed NFSv3 client for .NET — file operations, directory listing, streaming reads/writes</Description>
    <PackageTags>nfs;nfs-v3;storage;backup;network</PackageTags>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>
</Project>
